# ─── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-50-chars
DEBUG=False
# Comma-separated. Add your domain and server IP.
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,YOUR_SERVER_IP
# Comma-separated origins allowed for CORS (your Flutter app origin if needed)
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOW_ALL_ORIGINS=False

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=oyno
DB_USER=oyno
DB_PASSWORD=choose-a-strong-password
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── SMS / Twilio (optional — needed for phone OTP) ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
